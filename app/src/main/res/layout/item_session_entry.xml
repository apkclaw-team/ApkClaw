<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_session_panel"
    android:orientation="horizontal"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSessionName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#101828"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentSession"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_session_tag"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:text="@string/session_memory_current_badge"
                android:textColor="#1E7D34"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSessionMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#667085"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.apk.claw.android.widget.KButton
            android:id="@+id/btnOpenSession"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="@string/session_memory_open_chat"
            android:textSize="12sp"
            app:btnCornerRadius="14dp" />

        <com.apk.claw.android.widget.KButton
            android:id="@+id/btnDeleteSession"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="@string/session_memory_delete_action"
            android:textSize="12sp"
            app:btnBackground="@color/colorErrorContainer"
            app:btnBorderColor="@color/colorErrorPrimary"
            app:btnTextColor="@color/colorErrorOnContainer"
            app:btnCornerRadius="14dp" />
    </LinearLayout>

</LinearLayout>
